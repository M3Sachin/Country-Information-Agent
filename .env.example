# .env template for Country Info Agent
# Get free auth token from https://puter.com/dashboard

# Puter Configuration (FREE - No API key needed!)
PUTER_AUTH_TOKEN=your_puter_auth_token_here

# Gemini Model (gemini-2.5-flash, gemini-2.0-flash, etc.)
GEMINI_MODEL=gemini-2.5-flash

# API Configuration
API_BASE_URL=https://restcountries.com/v3.1
API_TIMEOUT=10
MAX_RETRIES=3
RATE_LIMIT_DELAY=0.1

# HTTP Pool Configuration
POOL_CONNECTIONS=10
POOL_MAXSIZE=20

# Logging
LOG_LEVEL=INFO